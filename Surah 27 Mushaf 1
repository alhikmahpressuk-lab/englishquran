<!DOCTYPE html>
<html lang="en" translate="no" class="notranslate">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
  <meta name="google" content="notranslate" />
  <meta name="translate" content="no" />
  <meta http-equiv="Content-Language" content="en" />
  <title>Surah 27 Mushaf | The Open Quran</title>
  <meta name="description" content="Surah 27 Mushaf reader from The Open Quran." />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

    :root {
      --bg: #f7f8fa;
      --surface: #ffffff;
      --surface-soft: #f2f5f6;
      --text: #182128;
      --muted: #66727d;
      --line: #e3e8ec;
      --accent: #1e6b5c;
      --accent-deep: #154d42;
      --accent-soft: #e8f3f0;
      --shadow: 0 14px 40px rgba(16, 24, 40, 0.06);
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      margin: 0;
      font-family: "Inter", Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
    }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(12px);
      background: color-mix(in srgb, var(--bg) 92%, transparent);
      border-bottom: 1px solid color-mix(in srgb, var(--line) 95%, transparent);
    }
    .topbar-inner, .container, .footer-inner {
      width: min(var(--max), calc(100% - 28px));
      margin: 0 auto;
    }
    .topbar-inner {
      min-height: 78px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
      padding: 12px 0;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
    }
    .brand-mark {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--accent), var(--accent-deep));
      color: #fff;
      display: grid;
      place-items: center;
      font-size: 1rem;
      font-weight: 800;
      box-shadow: var(--shadow);
      flex-shrink: 0;
    }
    .brand-text h1 {
      margin: 0;
      font-size: 1.05rem;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }
    .brand-text p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .nav a,
    .nav button,
    .toolbar-btn,
    .page-pill {
      min-height: 44px;
      padding: 0 16px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      font-weight: 600;
      transition: 0.2s ease;
      white-space: nowrap;
    }
    .nav a:hover,
    .nav button:hover,
    .toolbar-btn:hover {
      background: var(--surface-soft);
      border-color: color-mix(in srgb, var(--accent) 35%, var(--line));
    }
    .nav .cta,
    .toolbar-btn.primary {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .nav .cta:hover,
    .toolbar-btn.primary:hover {
      background: var(--accent-deep);
      border-color: var(--accent-deep);
    }
    .page-pill {
      background: var(--accent-soft);
      color: var(--accent-deep);
      border-color: color-mix(in srgb, var(--accent) 24%, var(--line));
      cursor: default;
    }

    .hero {
      padding: 26px 0 14px;
    }
    .hero-card,
    .viewer-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 24px;
      box-shadow: var(--shadow);
    }
    .hero-card {
      padding: 24px;
    }
    .crumb {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-deep);
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .hero-card h2 {
      margin: 0;
      font-size: clamp(1.9rem, 4vw, 2.7rem);
      line-height: 1.04;
      letter-spacing: -0.045em;
    }
    .hero-card p {
      margin: 12px 0 0;
      color: color-mix(in srgb, var(--text) 84%, white);
      max-width: 72ch;
    }

    .section {
      padding: 10px 0 34px;
    }
    .viewer-card {
      padding: 18px;
    }
    .mushaf-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .mushaf-toolbar-left,
    .mushaf-toolbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .status {
      padding: 12px 14px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: var(--surface-soft);
      color: color-mix(in srgb, var(--text) 88%, white);
      font-size: 0.95rem;
      margin-bottom: 14px;
    }

    .mushaf-frame-shell {
      border-radius: 20px;
      border: 1px solid var(--line);
      background: color-mix(in srgb, var(--surface-soft) 75%, var(--surface));
      padding: 10px;
      direction: rtl;
    }
    .mushaf-frame {
      width: 100%;
      min-height: 82vh;
      border: 0;
      border-radius: 16px;
      background: #fff;
      box-shadow: var(--shadow);
    }

    .footer {
      padding: 0 0 34px;
    }
    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 0.92rem;
    }

    @media (max-width: 760px) {
      .topbar-inner {
        align-items: stretch;
      }
      .nav {
        width: 100%;
      }
      .mushaf-frame {
        min-height: 74vh;
      }
    }
  </style>
</head>
<body translate="no" class="notranslate">
  <header class="topbar notranslate" translate="no">
    <div class="topbar-inner">
      <div class="brand">
        <div class="brand-mark" translate="no">م</div>
        <div class="brand-text">
          <h1 translate="no">The Open Quran</h1>
          <p translate="no">Mushaf Reading</p>
        </div>
      </div>
      <nav class="nav" aria-label="Primary">
        <a href="index.html" translate="no">Back to Surah 27</a>
        <a class="cta" href="#mushafReader" translate="no">Open Mushaf</a>
      </nav>
    </div>
  </header>

  <main translate="no" class="notranslate">
    <section class="hero">
      <div class="container">
        <div class="hero-card">
          <div class="crumb" translate="no">Mushaf · Surah 27 · An-Naml</div>
          <h2 translate="no">Surah 27 Mushaf Reading</h2>
          <p translate="no">Read Surah An-Naml in a simple Arabic Mushaf view with a clear layout and easy page navigation.</p>
        </div>
      </div>
    </section>

    <section class="section" id="mushafReader">
      <div class="container">
        <div class="viewer-card">
          <div class="mushaf-toolbar">
            <div class="mushaf-toolbar-left">
              <span class="page-pill" translate="no">Surah 27</span>
              <span class="page-pill" id="pageRangeLabel" translate="no">Surah 27 Pages</span>
            </div>
            <div class="mushaf-toolbar-right">
              <button class="toolbar-btn" type="button" id="prevPageButton" translate="no">Previous</button>
              <span class="page-pill" id="currentPagePill" translate="no">Page 1</span>
              <button class="toolbar-btn" type="button" id="nextPageButton" translate="no">Next</button>
              <button class="toolbar-btn primary" type="button" id="quickLoadButton" translate="no">Quick Load</button>
            </div>
          </div>
          <div class="status" id="mushafStatus" translate="no">Preparing Surah 27 Mushaf…</div>
          <div class="mushaf-frame-shell">
            <iframe id="mushafFrame" class="mushaf-frame" title="Surah 27 Mushaf PDF" loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer notranslate" translate="no">
    <div class="footer-inner">
      <div translate="no">Surah 27 Mushaf Reader</div>
      <div translate="no">© openquran.uk. All rights reserved.</div>
    </div>
  </footer>

  <script>
    const mushafConfig = {
      title: 'Surah 27 · An-Naml',
      file: encodeURI("THE ARABIC QUR'AN.pdf"),
      startPage: 463,
      endPage: 471
    };

    const mushafStatus = document.getElementById('mushafStatus');
    const mushafFrame = document.getElementById('mushafFrame');
    const pageRangeLabel = document.getElementById('pageRangeLabel');
    const currentPagePill = document.getElementById('currentPagePill');
    const prevPageButton = document.getElementById('prevPageButton');
    const nextPageButton = document.getElementById('nextPageButton');
    const quickLoadButton = document.getElementById('quickLoadButton');

    let currentPage = mushafConfig.startPage;

    function getDisplayPageNumber() {
      return (currentPage - mushafConfig.startPage) + 1;
    }

    function buildPdfUrl(pageNumber) {
      const safePage = Math.min(mushafConfig.endPage, Math.max(mushafConfig.startPage, Number(pageNumber) || mushafConfig.startPage));
      return `${mushafConfig.file}#page=${safePage}&zoom=page-width`;
    }

    function updateMushafFrame(pageNumber) {
      currentPage = Math.min(mushafConfig.endPage, Math.max(mushafConfig.startPage, Number(pageNumber) || mushafConfig.startPage));
      pageRangeLabel.textContent = 'Surah 27 Pages';
      currentPagePill.textContent = `Page ${getDisplayPageNumber()}`;
      prevPageButton.disabled = currentPage <= mushafConfig.startPage;
      nextPageButton.disabled = currentPage >= mushafConfig.endPage;
      mushafFrame.src = buildPdfUrl(currentPage);
      mushafStatus.textContent = `${mushafConfig.title} is ready. Use Previous and Next to continue reading.`;
    }

    prevPageButton.addEventListener('click', () => {
      updateMushafFrame(currentPage - 1);
    });

    nextPageButton.addEventListener('click', () => {
      updateMushafFrame(currentPage + 1);
    });

    mushafFrame.addEventListener('load', () => {
      mushafStatus.textContent = `${mushafConfig.title} is ready. Continue reading with the minimal controls above.`;
    });

    mushafFrame.addEventListener('error', () => {
      mushafStatus.textContent = 'The Mushaf could not be displayed right now. Use Quick Load to try again.';
    });

    quickLoadButton.addEventListener('click', () => {
      mushafStatus.textContent = 'Preparing Surah 27 Mushaf…';
      updateMushafFrame(currentPage || mushafConfig.startPage);
    });

    updateMushafFrame(mushafConfig.startPage);
  </script>
</body>
</html>

